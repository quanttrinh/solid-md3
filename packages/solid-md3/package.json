        "material-design",
        "md3",
        "solid",
        "solid-js",
        "ui"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/quanttrinh/solid-md3.git"
    },
    "files": [
        "src"
    ],
    "type": "module",
    "sideEffects": [
        "./src/styles.css"
    ],
    "main": "./src/index.ts",
    "module": "./src/index.ts",
