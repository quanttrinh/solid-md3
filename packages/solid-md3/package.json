        "clsx": "^2.1.1",
        "eslint-plugin-solid": "^0.14.5",
        "fuse.js": "^7.4.2",
        "oxfmt": "^0.60.0",
        "oxlint": "^1.74.0",
        "oxlint-tsgolint": "^0.24.0",
        "solid-js": "^1.9.13",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.2"
    },
    "peerDependencies": {
        "@ark-ui/solid": "^5.37.1",
        "@iconify-solid/material-symbols": "^1.0.23",
        "@tanstack/solid-pacer": "^0.21.1",
